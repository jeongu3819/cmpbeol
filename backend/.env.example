# DB 접속 URL (실제 비밀번호로 교체해서 backend/.env 에 저장)
# 기존 HeidiSQL 에 만들어 둔 cmpbeol DB 를 그대로 사용합니다.
DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/cmpbeol

# 앱 실행 시 없는 테이블만 생성할지 여부.
# 이미 HeidiSQL 에서 테이블을 만들어 두었다면 false 로 둡니다. (기존 테이블/데이터 유지)
AUTO_CREATE_TABLES=false

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Step 이미지 업로드 저장 디렉터리 (backend 기준 상대경로 또는 절대경로)
UPLOAD_DIR=uploads
